{
  "name": "bdd-reporting-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Miniature monorepo — UI + backend + integration tests — for exercising advanced GitHub CI reporting patterns",
  "type": "module",
  "workspaces": [
    "packages/*",
    "components/ui",
    "components/integration"
  ],
  "scripts": {
    "build:reporter": "npm --workspace cucumber-ctrf-json-reporter run build",
    "test:ui": "npm --workspace ui run test",
    "test:integration": "npm --workspace integration run test"
  }
}
